{
  "properties": {
    "displayName": "Restrict Virtual Machine SKU Sizes",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "This policy restricts the SKU sizes that can be deployed for virtual machines to approved B-series sizes only.",
    "metadata": {
      "category": "Compute",
      "version": "1.0.0"
    },
    "parameters": {},
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Compute/virtualMachines"
          },
          {
            "not": {
              "field": "Microsoft.Compute/virtualMachines/sku.name",
              "in": [
                "Standard_B1ls",
                "Standard_B1s",
                "Standard_B1ms",
                "Standard_B2s",
                "Standard_B2ms",
                "Standard_B2mts",
                "Standard_B4ms",
                "Standard_B8ms"
              ]
            }
          }
        ]
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}
